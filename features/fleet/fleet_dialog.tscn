[node name="FleetDialog" type="Window"]
title = "Flotte"
initial_position = 2
min_size = Vector2i(400, 300)
wrap_controls = true
transient = true
exclusive = true
unresizable = false
script = ExtResource("1")

[node name="PanelContainer" type="PanelContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_styles/panel = ExtResource("2_style")

[node name="VBox" type="VBoxContainer" parent="PanelContainer"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="NameLabel" type="Label" parent="PanelContainer/VBox"]
layout_mode = 2
text = "Nom de la flotte"

[node name="NameEdit" type="LineEdit" parent="PanelContainer/VBox"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Entrez le nom..."

[node name="TypeLabel" type="Label" parent="PanelContainer/VBox"]
layout_mode = 2
text = "Type de drone"

[node name="TypeOption" type="OptionButton" parent="PanelContainer/VBox"]
unique_name_in_owner = true
layout_mode = 2

[node name="CountLabel" type="Label" parent="PanelContainer/VBox"]
layout_mode = 2
text = "Nombre de drones"

[node name="CountSpin" type="SpinBox" parent="PanelContainer/VBox"]
unique_name_in_owner = true
layout_mode = 2
min_value = 1.0
max_value = 9999.0
value = 1.0

[node name="Sep2" type="HSeparator" parent="PanelContainer/VBox"]
layout_mode = 2
theme_override_colors/separator_color = Color(0.3, 0.3, 0.35, 1)

[node name="ButtonsRow" type="HBoxContainer" parent="PanelContainer/VBox"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 12

[node name="DeleteBtn" type="Button" parent="PanelContainer/VBox/ButtonsRow"]
unique_name_in_owner = true
layout_mode = 2
theme_override_styles/normal = SubResource("btn_delete_style")
