[node name="Spacer" type="Control" parent="PanelContainer/VBox/ButtonsRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="CancelBtn" type="Button" parent="PanelContainer/VBox/ButtonsRow"]
unique_name_in_owner = true
layout_mode = 2
theme_override_styles/normal = SubResource("btn_cancel_style")
text = "Annuler"

[node name="ValidateBtn" type="Button" parent="PanelContainer/VBox/ButtonsRow"]
unique_name_in_owner = true
